*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ===== 虚拟环境 =====
venv/
.venv/
env/
ENV/

# ===== Node.js =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== 前端构建 =====
frontend/dist/

# ===== Vite =====
.vite/

# ===== 知识库数据（运行时生成） =====
data/vector_store/
data/uploads/
data/evaluation/

# ===== 环境变量 =====
.env
.env.local
.env.*.local

# ===== IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ===== OS =====
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== 日志 =====
*.log
logs/

# ===== 测试 =====
.pytest_cache/
.coverage
htmlcov/
