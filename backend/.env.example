# ===== 环境工程 RAG Ultimate 环境变量配置 =====
# API Key 由前端用户传入，无需在服务端配置

# ===== 应用配置 =====
DEBUG=false

# ===== 默认模型 =====
DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_LLM_MODEL=deepseek-chat

# ===== Embedding =====
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu

# ===== Reranker =====
RERANKER_MODEL=BAAI/bge-reranker-base
USE_RERANKER=true
RERANKER_TOP_K=20

# ===== Query Transform =====
ENABLE_QUERY_REWRITE=true
ENABLE_MULTI_QUERY=false

# ===== RAG =====
CHUNK_SIZE=512
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7
